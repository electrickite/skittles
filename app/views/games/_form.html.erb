<%= simple_form_for game do |f| %>
  <%= f.input :name %>

  <%= f.simple_fields_for :players do |p| %>
    <%= p.association :user, label: "#{p.object.color.humanize} player", include_blank: 'AI' %>
    <%= p.hidden_field :color %>
  <% end %>

  <%= f.button :submit, 'Save' %>

  <%= link_to 'Cancel', (game.new_record? ? games_path : game), class: 'btn btn-link' %>
<% end %>
