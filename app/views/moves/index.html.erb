<%- content_for(:title) { 'Moves' } -%>

<table class="table">
  <thead>
    <tr>
      <th>Game</th>
      <th>Number</th>
      <th>Color</th>
      <th>Notation</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @moves.each do |move| %>
      <tr>
        <td><%= move.game %></td>
        <td><%= move.number %></td>
        <td><%= move.color %></td>
        <td><%= move.notation %></td>
        <td><%= link_to 'Show', move %></td>
        <td><%= link_to 'Edit', edit_move_path(move) %></td>
        <td><%= link_to 'Destroy', move, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Move', new_move_path %>
