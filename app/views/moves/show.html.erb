<%- content_for(:title) { "Move #{@move.number}" } -%>
<%- content_for(:back_link) { link_to 'Back', game_moves_path(@move.game) } -%>

<p>
  <strong>Game:</strong>
  <%= link_to @move.game, @move.game %>
</p>

<p>
  <strong>Number:</strong>
  <%= @move.number %>
</p>

<p>
  <strong>Color:</strong>
  <%= @move.color %>
</p>

<p>
  <strong>Notation:</strong>
  <%= @move.notation %>
</p>

<p>
  <strong>Played:</strong>
  <%= @move.created_at %>
</p>

<%= render partial: "board", object: @move %>

<nav class="move-nav" aria-label="Move navigation">
  <ul class="pager">
    <li class="previous <%= 'disabled' if @move.previous.nil? %>">
      <%= link_to(@move.previous) do %>
        <span aria-hidden="true">&larr;</span> Previous
      <% end %>
    </li>
    <li>
      <%= link_to 'All', game_moves_path(@move.game) %>
    </li>
    <li class="next <%= 'disabled' if @move.next.nil? %>">
      <%= link_to(@move.next) do %>
        Next <span aria-hidden="true">&rarr;</span>
      <% end %>
    </li>
  </ul>
</nav>
