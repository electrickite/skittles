<%- content_for(:title) { 'Users' } -%>

<table class="table">
  <thead>
    <tr>
      <th>Username</th>
      <th colspan="2"></th>
    </tr>
  </thead>

  <tbody>
    <%- if @users.each do |user| -%>
      <tr>
        <td><%= user.username %></td>
        <td><%= link_to 'Show', user %></td>
        <td><%= link_to 'Destroy', user, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <%- end.empty? -%>
      <tr>
        <td colspan="9">There are currently no users. <%= link_to 'Sign up', new_user_registration_path %></td>
      </tr>
    <%- end -%>
  </tbody>
</table>
